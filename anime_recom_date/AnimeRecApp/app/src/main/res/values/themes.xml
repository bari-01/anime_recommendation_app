<resources>
    <!-- Base application theme (Material3) — Light / Coffee-Cream -->
    <style name="Theme.AnimeRec" parent="Theme.Material3.Light">
        <!-- Primary brand color — coffee brown -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryContainer">@color/surface_variant_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnPrimaryContainer">@color/purple_700</item>
        <!-- Secondary brand color — warm coral -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryContainer">#FFFFCCBC</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorOnSecondaryContainer">@color/teal_700</item>
        <!-- Tertiary — amber -->
        <item name="colorTertiary">@color/purple_200</item>
        <item name="colorOnTertiary">@color/purple_700</item>
        <!-- Surface — creamy -->
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/on_surface_light</item>
        <item name="colorSurfaceVariant">@color/surface_variant_light</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant_light</item>
        <!-- Outline -->
        <item name="colorOutline">#FFBCAAA4</item>
        <item name="colorOutlineVariant">#FFD7CCC8</item>
        <!-- Error -->
        <item name="colorError">#B3261E</item>
        <item name="colorOnError">@color/white</item>
        <!-- Status bar — coffee brown -->
        <item name="android:statusBarColor">@color/status_bar_light</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- Bottom nav background — warm cream -->
        <item name="android:navigationBarColor">@color/bottom_nav_light</item>
    </style>

    <!-- Splash theme -->
    <style name="SplashTheme" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@color/surface_light</item>
        <item name="android:statusBarColor">@color/purple_700</item>
        <item name="android:windowTranslucentStatus">false</item>
    </style>
</resources>
